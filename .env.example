# Banco (Neon) — obrigatória
DATABASE_URL=

# Gate de senha do dashboard (transição, sai na Fase 7). Vazio = aberto.
DASHBOARD_PASSWORD=

# Stack Auth — MESMO projeto do portal (cliente.casaldotrafego.com).
# Sem estas três, o app degrada para o gate de senha acima e continua no ar.
NEXT_PUBLIC_STACK_PROJECT_ID=
NEXT_PUBLIC_STACK_PUBLISHABLE_CLIENT_KEY=
STACK_SECRET_SERVER_KEY=

# Superadmins (mesma lista do portal). Sem estas, ninguém é superadmin.
ADMIN_EMAILS=
SUPERADMIN_EMAIL=

# Chave para decifrar o token da Meta gravado pelo /admin do portal.
# 32 bytes em base64 (openssl rand -base64 32), IGUAL à do portal.
AGENTS_SECRET_KEY=

# Control API do Hermes (pausar/retomar o bot na aba Conversas)
PAINEL_API_TOKEN=
HERMES_PANEL_URL=https://hermes.casaldotrafego.com/agente

# WhatsApp Cloud API da Meta (envio manual de texto + templates aprovados).
# phone_number_id, waba_id e fonte de leads vêm do catálogo (public.agents).
# Estas envs são o fallback de token dos 3 agentes atuais.
META_ACCESS_TOKEN=
META_ACCESS_TOKEN_DRLUCAS=
# Opcional: sobrescreve a versão da Graph API (padrão v21.0)
# META_GRAPH_VERSION=v21.0

# Segredo do cron de disparos (app/api/dispatch/run)
DISPATCH_CRON_SECRET=
